# ============================================================
# Operating system files
# ============================================================

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini


# ============================================================
# Editor and IDE files
# ============================================================

.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.swp
*.swo


# ============================================================
# MATLAB temporary/generated files
# ============================================================

*.asv
*.m~
*.mex*
*.fig
*.mlx.autosave
slprj/
codegen/
html/


# ============================================================
# MATLAB data files
# Usually avoid committing binary workspace data unless intentional
# ============================================================

*.mat


# ============================================================
# Python temporary/generated files
# ============================================================

__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.ipynb_checkpoints/
.pytest_cache/


# ============================================================
# OpenSim generated outputs
# ============================================================

results/
result/
outputs/
output/
analysis/
Analysis/
Reports/
reports/

*_InverseDynamics_*.sto
*_StaticOptimization_*.sto
*_BodyKinematics_*.sto
*_Kinematics_*.sto
*_PointKinematics_*.sto
*_JointReaction_*.sto
*_states.sto
