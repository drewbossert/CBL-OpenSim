# ============================================================
# OpenSim / biomechanics data files
# Default: ignore raw/generated data files
# Commit only small anonymized examples through explicit exceptions below
# ============================================================

*.mot
*.sto
*.trc
*.c3d
*.anc
*.forces
*.grf
*.csv
*.tsv
*.xlsx
*.xls


# ============================================================
# Geometry and mesh files
# Usually too large or derived from protected source data
# ============================================================

*.stl
*.obj
*.ply
*.vtk
*.vtp
*.vtu
*.msh
*.foam


# ============================================================
# Medical image / CT / segmentation files
# Do not commit protected or source imaging data
# ============================================================

*.dcm
*.nii
*.nii.gz
*.nrrd
*.nhdr
*.mha
*.mhd
*.seg.nrrd


# ============================================================
# Local/private configuration
# ============================================================

local_config.*
paths_config.*
private_config.*
credentials.*
secrets.*
.env


# ============================================================
# Logs and temporary files
# ============================================================

*.log
*.tmp
*.temp
*.bak
~$*
temp/
tmp/


# ============================================================
# Allow selected template/example files
# ============================================================

!data_templates/**/*.mot
!data_templates/**/*.sto
!data_templates/**/*.trc
!data_templates/**/*.csv
!data_templates/**/*.xml

!tutorials/tutorial_data/**/*.mot
!tutorials/tutorial_data/**/*.sto
!tutorials/tutorial_data/**/*.trc
!tutorials/tutorial_data/**/*.csv
!tutorials/tutorial_data/**/*.xml

!opensim/setup_templates/**/*.xml
!opensim/analysis_templates/**/*.xml
!opensim/actuator_templates/**/*.xml

!config/example_*
!**/README.md
